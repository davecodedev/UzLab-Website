{
  "name": "uzlab-website",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/api && npm run lint --workspace=apps/web",
    "typecheck": "npm run typecheck --workspace=apps/api && npm run typecheck --workspace=apps/web",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/api",
    "prisma:generate": "npm run prisma:generate --workspace=apps/api",
    "prisma:studio": "npm run prisma:studio --workspace=apps/api"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "bcrypt@6.0.0": true,
    "fsevents@2.3.3": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "puppeteer@25.3.0": true
  }
}
