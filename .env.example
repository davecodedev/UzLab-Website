# --- Database (apps/api) ---
DATABASE_URL="postgresql://uzlab:uzlab_dev_password@localhost:5432/uzlab?schema=public"

# --- Auth (apps/api) ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# --- Object storage (apps/api) — MinIO locally, S3-compatible in prod ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="uzlab-documents"
S3_ACCESS_KEY_ID="uzlab_minio"
S3_SECRET_ACCESS_KEY="uzlab_minio_password"
S3_FORCE_PATH_STYLE="true"

# --- API server ---
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# --- Web app (apps/web) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
